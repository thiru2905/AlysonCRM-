# Get a key at https://platform.deepseek.com — never commit real values.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# App
PORT=8820
HOST=127.0.0.1
DATA_DIR=./data

# Agent limits
MAX_ITERATIONS=20
TASK_BUDGET_USD=0.02
TASK_TIMEOUT_MS=300000
WRITE_REQUIRES_APPROVAL=true

# Pricing (USD per 1M tokens) — DeepSeek V4 Flash defaults
PRICE_INPUT_PER_M=0.14
PRICE_OUTPUT_PER_M=0.28
PRICE_CACHE_HIT_PER_M=0.0028

# Dedicated Chrome profile (never your normal Chrome profile)
CHROME_USER_DATA_DIR=~/.browser-agent/chrome-profile
# Hermes opens normal Chrome (no "test software" banner) then attaches via debug port
CHROME_NATIVE_LAUNCH=true
CHROME_STEALTH_MODE=true
CHROME_DEBUG_PORT=9222
# CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# Leave empty to let Hermes launch Chrome. Set to attach to an already-running instance:
# CHROME_BROWSER_URL=http://127.0.0.1:9222
CHROME_BROWSER_URL=

# Optional CRM push (only after explicit record approval)
CRM_ENDPOINT=
CRM_API_KEY=
