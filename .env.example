# ---------------------------------------------------------------------------
# Alyson OS environment variables. Copy to `.env` and fill in real values.
# Never commit `.env` (see .gitignore). Only VITE_* vars reach the browser.
# ---------------------------------------------------------------------------

# Deploy target for Nitro at build time: node-server | vercel | cloudflare-pages
# Use vercel when deploying to Vercel.
NITRO_PRESET=vercel

# --- Recruiting module: candidate data provider -----------------------------
# Provider selection: mock | coresignal | pdl
CANDIDATE_PROVIDER=coresignal
# Coresignal (server-side only — never exposed to the browser)
# CORESIGNAL_API_KEY=RMetuDZ9BKGTLiYFqKvXbN7QNvcTtcmw
# CORESIGNAL_MAX_COLLECT=10
# People Data Labs (server-side only). Free tier ~100 lookups/month.
# Free key: https://dashboard.peopledatalabs.com
PDL_API_KEY=
# Max records fetched per PDL search (each returned record = 1 credit).
PDL_MAX_SIZE=5

# --- LinkedIn Search Builder: AI relevance scoring (server-side only) ---------
# Get a key at https://platform.deepseek.com
DEEPSEEK_API_KEY=

# --- Optional: Supabase persistence -----------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
