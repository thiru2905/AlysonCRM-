# ---------------------------------------------------------------------------
# Alyson OS environment variables. Copy to `.env` and fill in real values.
# Never commit `.env` (see .gitignore). Only VITE_* vars reach the browser.
# ---------------------------------------------------------------------------

# Deploy target for Nitro at build time: node-server | vercel | cloudflare-pages
# Use vercel when deploying to Vercel.
NITRO_PRESET=vercel

# --- Recruiting module: candidate data provider -----------------------------
# Provider selection: mock | coresignal | pdl
CANDIDATE_PROVIDER=coresignal
# Coresignal (server-side only — never exposed to the browser)
# CORESIGNAL_API_KEY=RMetuDZ9BKGTLiYFqKvXbN7QNvcTtcmw
# CORESIGNAL_MAX_COLLECT=10
# People Data Labs (server-side only). Free tier ~100 lookups/month.
# Free key: https://dashboard.peopledatalabs.com
PDL_API_KEY=
# Max records fetched per PDL search (each returned record = 1 credit).
PDL_MAX_SIZE=5

# --- Alyson Desktop Agent + Automation Platform (server-side) ---------------
# SQLite database path (optional; default: data/alyson-platform.db)
# ALYSON_AGENT_DB_PATH=
# Desktop agent HTTP endpoint (CRM dispatches automations here)
ALYSON_DESKTOP_AGENT_URL=http://127.0.0.1:8787
# Browser MCP agent (Chrome DevTools) — started via npm run browser-agent:dev
ALYSON_BROWSER_AGENT_URL=http://127.0.0.1:8820
# LinkedIn provider: chrome (MVP) | linkedapi (future)
LINKEDIN_PROVIDER=chrome
# SAFETY: Automated LinkedIn connections get accounts restricted. Leave false.
LINKEDIN_OUTREACH_ENABLED=false
# Max automated connections per day (only if OUTREACH_ENABLED=true). Recommend 0-5.
LINKEDIN_MAX_CONNECTIONS_PER_DAY=0

# Get a key at https://platform.deepseek.com
DEEPSEEK_API_KEY=

# --- Hermes / LinkedIn outreach (server + browser agent) --------------------
# Approve each request in Hermes UI → Chrome sends on LinkedIn (recommended).
LINKEDIN_SEND_ON_APPROVE=true
# Optional global enable (not required when SEND_ON_APPROVE=true)
LINKEDIN_OUTREACH_ENABLED=true
# Safe daily cap for automated sends
LINKEDIN_MAX_CONNECTIONS_PER_DAY=10
# Human-paced timing (browser agent) — mimics manual browsing
LINKEDIN_HUMAN_PACING=true
LINKEDIN_MIN_ACTION_DELAY_MS=2500
LINKEDIN_MAX_ACTION_DELAY_MS=6500
LINKEDIN_BETWEEN_PROFILE_DELAY_MS=45000
CHROME_NATIVE_LAUNCH=true
CHROME_STEALTH_MODE=true
CHROME_DEBUG_PORT=9222
ALYSON_DESKTOP_AGENT_URL=http://127.0.0.1:8787
ALYSON_BROWSER_AGENT_URL=http://127.0.0.1:8820
ALYSON_CRM_URL=http://localhost:3000

# --- Optional: Supabase persistence -----------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
